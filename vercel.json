{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "agenda.camaleaoecoturismo.com" }],
      "destination": "https://www.camaleaoecoturismo.com.br/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
